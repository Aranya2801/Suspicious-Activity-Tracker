# Copy to .env and fill in real values. Never commit the actual .env file.

ENVIRONMENT=development
DEBUG=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://sat_user:sat_password@localhost:5432/sat_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# Generate a real value with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_INSECURE_DEFAULT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# --- GenAI Security Assistant ---
# Required for the /api/v1/assistant/query endpoint and the AI Assistant
# dashboard page to function. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- AI pipeline model paths ---
YOLO_MODEL_PATH=ai_models/weights/yolov8n.pt
ANOMALY_MODEL_PATH=ai_models/weights/anomaly_v1.joblib

# --- Object storage (recorded clips/snapshots) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=sat-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Frontend (set in frontend/.env.local, not this file) ---
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
